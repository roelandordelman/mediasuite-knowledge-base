@prefix ms:      <https://mediasuite.clariah.nl/vocab#> .
@prefix clariah: <https://roelandordelman.github.io/mediasuite-knowledge-base/vocab#> .
@prefix tadirah: <https://vocabs.dariah.eu/tadirah/> .
@prefix schema:  <https://schema.org/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

# ── Intermediate data products ────────────────────────────────────────────────
# Named individuals representing the outputs that flow between workflow steps.
# Typed as dcat:Dataset to stay aligned with DCAT used for collections.

ms:SearchResult       a dcat:Dataset ; rdfs:label "Search Result Set"@en ;
    schema:description "Items returned by a query before sampling or annotation."@en .

ms:SelectedCorpus     a dcat:Dataset ; rdfs:label "Selected Corpus"@en ;
    schema:description "Researcher-defined subset of items saved to the Workspace as a purposive sample."@en .

ms:AnnotatedCorpus    a dcat:Dataset ; rdfs:label "Annotated Corpus"@en ;
    schema:description "Media items enriched with researcher annotations (segments, tags, notes)."@en .

ms:ExportedData       a dcat:Dataset ; rdfs:label "Exported Data"@en ;
    schema:description "Data exported from the Media Suite for use in an external analysis environment. The reuse license of exported data follows the source collection: only CC0-licensed metadata may be freely redistributed; metadata from IPR-restricted collections cannot be exported for reuse."@en .

ms:AnalysisDataset    a dcat:Dataset ; rdfs:label "Analysis Dataset"@en ;
    schema:description "Processed dataset produced by quantitative or qualitative analysis."@en .

ms:DepositedOutput    a dcat:Dataset ; rdfs:label "Deposited Research Output"@en ;
    schema:description "A dataset, annotated corpus, or computational notebook deposited in a repository (Zenodo, DANS, institutional repo) to obtain a persistent identifier (DOI). Represents the infrastructure-adjacent endpoint of a workflow: archiving the research output and making it citable. The full scholarly publication workflow (writing, peer review, journal submission) is outside the scope of the research infrastructure model."@en .

ms:DataStory          a dcat:Dataset ; rdfs:label "Data Story"@en ;
    schema:description "An enhanced publication combining computational analysis, data visualisation, and scholarly narrative, hosted on the CLARIAH data stories platform (mediasuitedatastories.clariah.nl). A CLARIAH-specific output format that bridges the gap between raw research output and traditional scholarly publication. Requires citation of the collections, tools, and infrastructure used — a case where the research environment has a direct stake in the publication output."@en .
    # NOTE: Data Stories represent the closest point where research infrastructure and
    # scholarly publishing overlap. They are produced using Media Suite tools and data,
    # and are hosted within the CLARIAH ecosystem. Citation of tools and datasets is
    # not optional for this format — it is structural. This makes Data Stories a model
    # for how enhanced publications could/should handle provenance and citation more broadly.

ms:SavedQuerySet      a dcat:Dataset ; rdfs:label "Saved Query Set"@en ;
    schema:description "A set of named search queries saved to the Workspace project, ready for comparison in the Compare Tool. Distinct from a corpus (saved items) — the saved query is the search definition, not the result set. The Compare Tool operates on saved queries, not on item sets."@en .

ms:ComparisonResult   a dcat:Dataset ; rdfs:label "Comparison Result"@en ;
    schema:description "N-gram style visualisation showing the relative frequency of saved search queries over time across one or more collections. Analogous to Google Ngram Viewer but applied to audiovisual and media collection metadata."@en .

ms:StatementList      a dcat:Dataset ; rdfs:label "Fact-check Statement List"@en ;
    schema:description "Ranked list of check-worthy statements extracted from ASR/subtitle data by the FactRank model."@en .

ms:VisualCorpus       a dcat:Dataset ; rdfs:label "Visual Corpus"@en ;
    schema:description "Corpus of visually similar media items assembled via the Similarity Tool."@en .

ms:ExplorationPath    a dcat:Dataset ; rdfs:label "Exploration Path"@en ;
    schema:description "Recorded navigation path through linked data entities in the Explore Tool."@en .

ms:MethodologyRecord  a dcat:Dataset ; rdfs:label "Methodology Record"@en ;
    schema:description "Documented record of methodological choices, search strategies, and interpretive decisions."@en .

ms:Transcript         a dcat:Dataset ; rdfs:label "ASR Transcript"@en ;
    schema:description "Raw automatic speech recognition output for a set of audio or audiovisual items — text with timestamps, before manual correction or annotation. Distinct from ms:AnnotatedCorpus (which has been reviewed and enriched by a researcher)."@en .

ms:CollectionProfile  a dcat:Dataset ; rdfs:label "Collection Profile"@en ;
    schema:description "Statistical overview of metadata field completeness, enrichment coverage (e.g. proportion of items with ASR transcripts, subject tags, face recognition), and temporal patterns in annotation practice, produced by the Collection Inspector. Represents the data quality context for a research workflow — making 'data fractures' visible: gaps and inconsistencies arising from different annotation methods, temporal shifts in cataloguing practice, or uneven resource allocation across collection segments."@en .

ms:Fragment           a dcat:Dataset ; rdfs:label "Media Fragment"@en ;
    schema:description "A bounded temporal or spatial segment of a media item, defined by the researcher."@en .

ms:CitableFragment    a dcat:Dataset ; rdfs:label "Citable Media Fragment"@en ;
    schema:description "A media fragment with a stable, resolvable URI (e.g. IIIF) suitable for citation."@en .

# ── Workflow 1: Gender representation analysis ────────────────────────────────

ms:GenderWorkflow
    a clariah:Workflow ;
    schema:name "Gender representation analysis using Media Suite and SANE"@en ;
    schema:description "Studying gender representation in Dutch broadcast media, combining Media Suite search and annotation with secure analysis in SANE."@en ;
    clariah:workflowStatus "Fully supported" ;
    dcterms:source <https://mediasuitedatastories.clariah.nl/gender-research-intro/> ;
    schema:result ms:DataStory ;  # this workflow is documented as a CLARIAH Data Story
    schema:step ms:GW1, ms:GW2, ms:GW3, ms:GW4, ms:GW5 .

ms:GW1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Search collections"@en ;
    schema:instrument ms:SearchTool ;
    clariah:researchActivity tadirah:searching, tadirah:querying ;
    schema:result ms:SearchResult .

ms:GW2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Select corpus"@en ;
    schema:instrument ms:Workspace ;
    clariah:researchActivity clariah:Sampling, tadirah:collecting ;
    schema:result ms:SelectedCorpus .

ms:GW3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Annotate selected items"@en ;
    schema:instrument ms:AnnotationTool ;
    clariah:researchActivity tadirah:visualAnnotation, tadirah:audioAnnotation ;
    clariah:optional true ;
    schema:result ms:AnnotatedCorpus .

ms:GW4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Analyse in secure environment"@en ;
    schema:instrument <https://sane.surf.nl/> ;
    clariah:researchActivity tadirah:analyzing ;
    schema:result ms:AnalysisDataset .

ms:GW5 a schema:HowToStep ; schema:position 5 ;
    schema:name "Deposit and cite research output"@en ;
    schema:description "Archive the analysis dataset and annotated corpus in a certified repository to obtain a DOI. Repository options: (1) Zenodo (zenodo.org) — general-purpose, EOSC-aligned, free; deposit in the CLARIAH community (zenodo.org/communities/clariah/) for discoverability within CLARIAH; (2) DANS SSH Data Station (ssh.datastations.nl) — Dutch SSH-specific, FAIR-certified, preferred when the funder requires a certified repository; (3) institutional DataverseNL repositories — check funder requirements. Cite the collections, tools, and infrastructure used. The scholarly writing and journal submission workflow is outside the scope of the research infrastructure model."@en ;
    schema:instrument <https://zenodo.org>, <https://ssh.datastations.nl/> ;
    clariah:researchActivity tadirah:academicPublishing ;
    schema:result ms:DepositedOutput .

# ── Workflow 2: Search → annotate → export ────────────────────────────────────

ms:SearchAnnotateExportWorkflow
    a clariah:Workflow ;
    schema:name "Search, annotate, and export"@en ;
    schema:description "The core Media Suite research loop: search collections, sample items into a personal corpus, annotate, and export results."@en ;
    clariah:workflowStatus "Fully supported" ;
    schema:hasPart ms:FAIRAnnotationSharing ;
    schema:step ms:SAE1, ms:SAE2, ms:SAE3, ms:SAE4 .

ms:SAE1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Search and browse collections"@en ;
    schema:instrument ms:SearchTool, ms:CollectionInspector ;
    clariah:researchActivity tadirah:searching, tadirah:browsing ;
    schema:result ms:SearchResult .

ms:SAE2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Select and save corpus to Workspace"@en ;
    schema:instrument ms:Workspace ;
    clariah:researchActivity clariah:Sampling, tadirah:collecting ;
    schema:result ms:SelectedCorpus .

ms:SAE3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Annotate items and segments"@en ;
    schema:instrument ms:AnnotationTool, ms:ResourceViewer ;
    clariah:researchActivity tadirah:visualAnnotation, tadirah:audioAnnotation, tadirah:segmenting ;
    clariah:optional true ;
    schema:result ms:AnnotatedCorpus .

ms:SAE4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Export annotations and metadata"@en ;
    schema:description "Export researcher annotations and collection metadata from the Workspace. Note: only CC0-licensed metadata may be exported; metadata for IPR-restricted items cannot be redistributed."@en ;
    schema:instrument ms:Workspace ;
    clariah:researchActivity tadirah:dataIngestion ;
    clariah:optional true ;
    schema:result ms:ExportedData .

# ── Workflow 3: Quantitative analysis — open data ─────────────────────────────

ms:OpenDataAnalysisWorkflow
    a clariah:Workflow ;
    schema:name "Quantitative analysis of open data via API"@en ;
    schema:description "Programmatic retrieval of open collection data via the Open Images API or SPARQL endpoint, followed by analysis in a computational notebook."@en ;
    clariah:workflowStatus "Fully supported" ;
    schema:step ms:ODA1, ms:ODA2, ms:ODA3 .

ms:ODA1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Retrieve data via API or SPARQL"@en ;
    schema:instrument ms:OpenImagesAPI, ms:SoundVisionSPARQL ;
    clariah:researchActivity tadirah:querying, tadirah:dataIngestion ;
    schema:result ms:SelectedCorpus .

ms:ODA2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Analyse in computational notebook"@en ;
    schema:description "Programmatic analysis of retrieved data in a notebook environment. Jupyter is the most common implementation in the Media Suite context; RStudio, Google Colab, and similar environments are equally applicable."@en ;
    schema:instrument <https://jupyter.org> ;
    clariah:researchActivity tadirah:analyzing, tadirah:dataMining ;
    schema:result ms:AnalysisDataset .

ms:ODA3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Deposit and cite research output"@en ;
    schema:description "Archive the analysis dataset or computational notebook in a certified repository to obtain a DOI. Zenodo with the CLARIAH community tag (zenodo.org/communities/clariah/) is the natural choice for open data; DANS SSH Data Station (ssh.datastations.nl) for Dutch SSH deposits requiring a certified repository. Cite the Open Images API or SPARQL endpoint and the source collection."@en ;
    schema:instrument <https://zenodo.org>, <https://ssh.datastations.nl/> ;
    clariah:researchActivity tadirah:academicPublishing ;
    clariah:optional true ;
    schema:result ms:DepositedOutput .

# ── Workflow 4: Quantitative analysis — restricted data via SANE ─────────────

ms:RestrictedDataSANEWorkflow
    a clariah:Workflow ;
    schema:name "Quantitative analysis of restricted data via SANE"@en ;
    schema:description "Selection and sampling in the Media Suite; analysis in SANE where data providers retain full control. Requires SRAM group membership. Prerequisite: complete ms:SANEAccessSubWorkflow first to formalise access and receive the SANE environment."@en ;
    clariah:workflowStatus "Fully supported" ;
    schema:hasPart ms:SANEAccessSubWorkflow ;
    schema:step ms:RDS1, ms:RDS2, ms:RDS3, ms:RDS4 .

ms:RDS1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Search and sample corpus in Media Suite"@en ;
    schema:instrument ms:SearchTool, ms:Workspace ;
    clariah:researchActivity tadirah:searching, clariah:Sampling ;
    schema:result ms:SelectedCorpus .

ms:RDS2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Export selection for SANE"@en ;
    schema:description "Transfer the selected corpus from the Media Suite to the SANE environment. Current mechanism: a representative of the data owner (e.g. NISV) manually exports the researcher's selection and makes it available in SANE — this step is not self-service and requires coordination with the data owner. Planned replacement: the DAB (Data Access Broker) + ODRL mechanism under development in SSHOC-NL would automate or semi-automate this transfer based on machine-readable access policies, with a small manual approval check by the data owner remaining. Until DAB/ODRL is in place, this step is the primary bottleneck in the restricted-data analysis workflow."@en ;
    schema:instrument ms:Workspace ;
    clariah:researchActivity tadirah:dataIngestion ;
    schema:result ms:ExportedData .

ms:RDS3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Analyse in SANE"@en ;
    schema:instrument <https://sane.surf.nl/> ;
    clariah:researchActivity tadirah:analyzing, tadirah:dataMining ;
    schema:result ms:AnalysisDataset .

ms:RDS4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Deposit and cite research output"@en ;
    schema:description "Archive the analysis dataset in a certified repository to obtain a DOI. Repository options: Zenodo with CLARIAH community tag (zenodo.org/communities/clariah/); DANS SSH Data Station (ssh.datastations.nl) — preferred for structured Dutch SSH research data and when funder requires a certified repository; institutional DataverseNL for university compliance. Important: data provider agreements and SANE terms of use govern what derived data may be deposited publicly — verify with the data owner before export."@en ;
    schema:instrument <https://zenodo.org>, <https://ssh.datastations.nl/> ;
    clariah:researchActivity tadirah:academicPublishing ;
    clariah:optional true ;
    schema:result ms:DepositedOutput .

# ── Workflow 5: Quantitative analysis — on-premise ───────────────────────────

ms:OnPremiseAnalysisWorkflow
    a clariah:Workflow ;
    schema:name "Quantitative analysis of restricted data on-premise"@en ;
    schema:description "For embedded researchers with on-site access by arrangement with Sound & Vision. Selection in the Media Suite; analysis in a local environment at NISV."@en ;
    clariah:workflowStatus "Fully supported" ;
    schema:releaseNotes "Not self-service — access arranged directly with NISV on a case-by-case basis." ;
    schema:step ms:OPR1, ms:OPR2, ms:OPR3 .

ms:OPR1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Search and sample corpus in Media Suite"@en ;
    schema:instrument ms:SearchTool, ms:Workspace ;
    clariah:researchActivity tadirah:searching, clariah:Sampling ;
    schema:result ms:SelectedCorpus .

ms:OPR2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Access data in on-premise environment"@en ;
    clariah:researchActivity tadirah:dataIngestion ;
    schema:result ms:ExportedData .

ms:OPR3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Analyse locally"@en ;
    schema:instrument <https://jupyter.org> ;
    clariah:researchActivity tadirah:analyzing, tadirah:dataMining ;
    schema:result ms:AnalysisDataset .

# ── Workflow 6: ASR-based transcript research ─────────────────────────────────

ms:ASRTranscriptResearchWorkflow
    a clariah:Workflow ;
    schema:name "Research using automatic speech recognition transcripts"@en ;
    schema:description "Using the ASR data layer to search spoken content in audiovisual collections, identify relevant segments, and annotate speech patterns."@en ;
    clariah:workflowStatus "Fully supported" ;
    schema:step ms:ASR1, ms:ASR2, ms:ASR3, ms:ASR4 .

ms:ASR1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Search in ASR transcript layer"@en ;
    schema:instrument ms:SearchTool ;
    clariah:researchActivity tadirah:searching, tadirah:informationRetrieval ;
    schema:result ms:SearchResult .

ms:ASR2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Inspect transcript and media in Resource Viewer"@en ;
    schema:instrument ms:ResourceViewer ;
    clariah:researchActivity tadirah:browsing ;
    schema:result ms:SelectedCorpus .

ms:ASR3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Annotate speech segments"@en ;
    schema:instrument ms:AnnotationTool ;
    clariah:researchActivity tadirah:audioAnnotation, tadirah:segmenting ;
    clariah:optional true ;
    schema:result ms:AnnotatedCorpus .

ms:ASR4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Export annotations for analysis"@en ;
    schema:instrument ms:Workspace ;
    clariah:researchActivity tadirah:dataIngestion ;
    clariah:optional true ;
    schema:result ms:ExportedData .

# ── Workflow 7: Cross-collection comparative analysis ─────────────────────────

ms:CrossCollectionComparativeWorkflow
    a clariah:Workflow ;
    schema:name "Cross-collection comparative analysis"@en ;
    schema:description "Comparing search query results across collections and over time to identify trends, differences, and patterns in media coverage."@en ;
    clariah:workflowStatus "Fully supported" ;
    schema:step ms:CCA1, ms:CCA2, ms:CCA3, ms:CCA4 .

ms:CCA1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Define and run query per collection"@en ;
    schema:description "Search each collection individually with a query that defines the data to be compared. Cross-collection simultaneous search is not supported — each collection must be searched separately. Repeat this step for each collection or query variant."@en ;
    schema:instrument ms:SearchTool ;
    clariah:researchActivity tadirah:searching, tadirah:querying ;
    schema:result ms:SearchResult .

ms:CCA2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Save queries to Workspace"@en ;
    schema:description "Save each query definition to the Workspace project. The Compare Tool operates on saved query definitions, not on item sets — this step is the bridge between search and comparison."@en ;
    schema:instrument ms:Workspace ;
    clariah:researchActivity tadirah:collecting ;
    schema:result ms:SavedQuerySet .

ms:CCA3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Compare saved queries over time"@en ;
    schema:instrument ms:CompareTool, ms:StatisticalAnalysis ;
    clariah:researchActivity tadirah:comparing, tadirah:dataVisualization ;
    schema:result ms:ComparisonResult .

ms:CCA4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Export comparison visualisation"@en ;
    schema:description "Download the n-gram style comparison chart from the Compare Tool for use in publications or further analysis."@en ;
    schema:instrument ms:CompareTool ;
    clariah:researchActivity tadirah:dataVisualization ;
    clariah:optional true ;
    schema:result ms:ComparisonResult .

# ── Workflow 8: Fact-checking research ───────────────────────────────────────

ms:FactCheckingWorkflow
    a clariah:Workflow ;
    schema:name "Fact-checking research on broadcast media"@en ;
    schema:description "Identifying and investigating check-worthy claims in Dutch talk shows using the FactRank tool, followed by annotation and publication of findings."@en ;
    clariah:workflowStatus "Partially supported" ;
    schema:releaseNotes "FactRank is experimental and currently limited to a subset of Dutch talk shows from January 2024. Coverage expands as the model is updated." ;
    schema:step ms:FCR1, ms:FCR2, ms:FCR3, ms:FCR4 .

ms:FCR1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Query FactRank for check-worthy statements"@en ;
    schema:instrument ms:FactRankTool ;
    clariah:researchActivity tadirah:informationRetrieval, tadirah:discourseAnalysis ;
    schema:result ms:StatementList .

ms:FCR2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Review statements in Resource Viewer"@en ;
    schema:instrument ms:ResourceViewer ;
    clariah:researchActivity tadirah:browsing ;
    schema:result ms:SelectedCorpus .

ms:FCR3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Annotate findings"@en ;
    schema:instrument ms:AnnotationTool ;
    clariah:researchActivity tadirah:visualAnnotation, tadirah:audioAnnotation ;
    clariah:optional true ;
    schema:result ms:AnnotatedCorpus .

ms:FCR4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Deposit findings"@en ;
    schema:instrument <https://zenodo.org>, <https://ssh.datastations.nl/> ;
    clariah:researchActivity tadirah:academicPublishing ;
    clariah:optional true ;
    schema:result ms:DepositedOutput .

# ── Workflow 9: Similarity-based corpus building ──────────────────────────────

ms:SimilarityCorpusWorkflow
    a clariah:Workflow ;
    schema:name "Similarity-based visual corpus building"@en ;
    schema:description "Using the Similarity Tool to find visually similar audiovisual content, building a corpus of related items for visual pattern research."@en ;
    clariah:workflowStatus "Partially supported" ;
    schema:releaseNotes "Similarity Tool is experimental with limited archive coverage (only keyframe-processed items). Entry point is the 'Only resources with keyframes' filter in the Search Tool." ;
    schema:step ms:SCB1, ms:SCB2, ms:SCB3 .

ms:SCB1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Search with keyframe filter"@en ;
    schema:instrument ms:SearchTool ;
    clariah:researchActivity tadirah:searching, clariah:Sampling ;
    schema:result ms:SearchResult .

ms:SCB2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Find visually similar items"@en ;
    schema:instrument ms:SimilarityTool ;
    clariah:researchActivity tadirah:patternRecognition, tadirah:informationRetrieval ;
    schema:result ms:VisualCorpus .

ms:SCB3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Annotate visual patterns"@en ;
    schema:instrument ms:AnnotationTool ;
    clariah:researchActivity tadirah:visualAnnotation ;
    clariah:optional true ;
    schema:result ms:AnnotatedCorpus .

# ── Workflow 10: Linked data exploration ─────────────────────────────────────

ms:LinkedDataExplorationWorkflow
    a clariah:Workflow ;
    schema:name "Serendipitous discovery via linked data"@en ;
    schema:description "Open-ended exploration of collections by following linked data connections between entities — people, locations, concepts — to discover unexpected items and relationships."@en ;
    clariah:workflowStatus "Partially supported" ;
    schema:releaseNotes "Explore Tool is functional but currently being revamped. Covers Sound & Vision, EYE Film Museum, and Natuurbeelden collections." ;
    schema:step ms:LDE1, ms:LDE2, ms:LDE3 .

ms:LDE1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Browse entities via Explore Tool"@en ;
    schema:instrument ms:ExploreTool ;
    clariah:researchActivity tadirah:browsing, tadirah:linkedOpenData ;
    schema:result ms:ExplorationPath .

ms:LDE2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Follow linked data connections to discover items"@en ;
    schema:instrument ms:ExploreTool ;
    clariah:researchActivity tadirah:exploration ;
    schema:result ms:SelectedCorpus .

ms:LDE3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Save and annotate discovered items"@en ;
    schema:instrument ms:Workspace, ms:AnnotationTool ;
    clariah:researchActivity tadirah:collecting, tadirah:visualAnnotation ;
    clariah:optional true ;
    schema:result ms:AnnotatedCorpus .

# ── Workflow 11: Replicate from publication ───────────────────────────────────

ms:ReplicationWorkflow
    a clariah:Workflow ;
    schema:name "Replication and provenance tracing from research publication"@en ;
    schema:description "Starting from a published research paper that used the Media Suite, reconstructing the original search queries, verifying the corpus, and documenting the methodological chain for reproducibility."@en ;
    clariah:workflowStatus "Aspirational" ;
    schema:releaseNotes "Requires persistent query identifiers and structured methodology records not yet implemented. The Reflexivity Tool addresses the documentation step but query persistence is a gap." ;
    schema:step ms:REP1, ms:REP2, ms:REP3, ms:REP4 .

ms:REP1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Identify original search queries from publication"@en ;
    schema:instrument <https://zenodo.org> ;  # or institutional repository where paper is deposited
    clariah:researchActivity tadirah:finding ;
    schema:result ms:MethodologyRecord .

ms:REP2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Reconstruct search in Media Suite"@en ;
    schema:instrument ms:SearchTool ;
    clariah:researchActivity tadirah:searching, tadirah:querying ;
    schema:result ms:SearchResult .

ms:REP3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Compare reconstructed results with original"@en ;
    schema:instrument ms:CompareTool ;
    clariah:researchActivity tadirah:comparing ;
    clariah:optional true ;
    schema:result ms:ComparisonResult .

ms:REP4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Document methodology and deviations"@en ;
    schema:instrument ms:ReflexivityTool ;
    clariah:researchActivity tadirah:defining ;
    clariah:optional true ;
    schema:result ms:MethodologyRecord .

# ── Sub-workflow A: FAIR annotation sharing ───────────────────────────────────
# Operational pattern — appears as a step inside annotation workflows.
# Modelled as schema:hasPart of SearchAnnotateExportWorkflow.

ms:FAIRAnnotationSharing
    a clariah:Workflow ;
    schema:name "FAIR annotation sharing"@en ;
    schema:description "Exporting annotations from the Media Suite in a FAIR-compliant format and depositing them in a repository for community reuse."@en ;
    clariah:workflowStatus "Fully supported" ;
    dcterms:source <https://mediasuite.clariah.nl/learn/tool-tutorials/tutorial-sharing-media-suite-annotations-following-the-fair-principles> ;
    schema:step ms:FAIR1, ms:FAIR2 .

ms:FAIR1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Export annotations from Workspace"@en ;
    schema:instrument ms:Workspace ;
    clariah:researchActivity tadirah:dataIngestion ;
    schema:result ms:ExportedData .

ms:FAIR2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Deposit in FAIR repository"@en ;
    schema:description "Deposit the exported annotations in a FAIR-compliant repository. DANS SSH Data Station (ssh.datastations.nl) is the preferred choice for Dutch SSH research data and for deposits requiring a certified trustworthy repository. Zenodo with the CLARIAH community tag (zenodo.org/communities/clariah/) is suitable for open annotation sets. Note: annotations derived from open (CC0) collections may be freely deposited; annotations linked to restricted-access material require data provider agreement."@en ;
    schema:instrument <https://zenodo.org>, <https://ssh.datastations.nl/> ;
    clariah:researchActivity tadirah:academicPublishing ;
    schema:result ms:DepositedOutput .

# ── Sub-workflow B: Fragment citation via IIIF ────────────────────────────────
# Operational pattern — aspirational pending Fragment Cutter implementation.
# Intended to appear as a step inside annotation and viewing workflows.

ms:FragmentCitationSubWorkflow
    a clariah:Workflow ;
    schema:name "Fragment citation via IIIF"@en ;
    schema:description "Defining a temporal or spatial media fragment, obtaining a stable IIIF URI, and citing it in a publication or annotation."@en ;
    clariah:workflowStatus "Aspirational" ;
    schema:releaseNotes "Requires the Fragment Cutter tool (planned, not yet built) and IIIF manifest support for Media Suite items." ;
    schema:step ms:FC1, ms:FC2 .

ms:FC1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Define and save media fragment"@en ;
    schema:instrument ms:FragmentCutter ;
    clariah:researchActivity tadirah:segmenting ;
    schema:result ms:Fragment .

ms:FC2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Cite fragment via stable IIIF URI"@en ;
    clariah:researchActivity tadirah:persistentIdentifier ;
    schema:result ms:CitableFragment .

# ── Sub-workflow D: Formalising access to SANE ────────────────────────────────
# Administrative and procedural prerequisite to ms:RestrictedDataSANEWorkflow.
# The steps in this sub-workflow are procedural, not scholarly activities in
# the TaDiRaH sense; tadirah:managing is used as the closest available concept
# for the administrative steps.
# Currently available for NISV collections only (CLARIAH beta pilot).
# Documented at: https://roelandordelman.github.io/media-suite-community/sane/

ms:SANEAccessSubWorkflow
    a clariah:Workflow ;
    schema:name "Formalising access to SANE"@en ;
    schema:description "Administrative and procedural steps for obtaining access to SANE (Secure ANalysis Environment) for analysis of restricted Media Suite collections. A prerequisite to ms:RestrictedDataSANEWorkflow — complete this sub-workflow first, then proceed with corpus selection and analysis. Currently scoped to NISV collections only (CLARIAH beta pilot); other data providers are not yet a routed option. Key constraint: no data leaves SANE without data provider review and approval."@en ;
    clariah:workflowStatus "Fully supported" ;
    dcterms:source <https://roelandordelman.github.io/media-suite-community/sane/> ;
    schema:step ms:SA1, ms:SA2, ms:SA3, ms:SA4, ms:SA5 .

ms:SA1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Select corpus and document research motivation"@en ;
    schema:description "In the Media Suite Workspace, define which NISV collections and data are needed, and document the research motivation, methods, and intended use. This documentation forms the basis of the access request in the next step."@en ;
    schema:instrument ms:SearchTool, ms:Workspace ;
    clariah:researchActivity tadirah:searching, clariah:Sampling ;
    schema:result ms:SelectedCorpus .

ms:SA2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Submit SANE access request"@en ;
    schema:description "Submit the access request form via the Media Suite, providing: identity and institutional affiliation, desired NISV collections, research motivation and methods, and software and compute requirements. The Media Suite Broker checks eligibility and forwards the request to the data provider (NISV)."@en ;
    clariah:researchActivity tadirah:managing ;
    schema:result ms:MethodologyRecord .

ms:SA3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Complete data provider review and sign agreement"@en ;
    schema:description "NISV reviews the request. Depending on the collection and intended use, the researcher may be required to sign a confidentiality or data-use agreement. This step is data provider-driven; the researcher waits and responds to agreement requirements. Approval is not guaranteed."@en ;
    clariah:researchActivity tadirah:managing .

ms:SA4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Receive SANE environment"@en ;
    schema:description "SURF configures the secure workspace upon approval, typically ~30 minutes for a basic environment (1 core, 8 GB RAM). The researcher receives access to SANE with the agreed data loaded and standard tools (R, Python) available. Larger compute configurations can be requested."@en ;
    schema:instrument <https://sane.surf.nl/> ;
    clariah:researchActivity tadirah:managing .

ms:SA5 a schema:HowToStep ; schema:position 5 ;
    schema:name "Output review and environment closeout"@en ;
    schema:description "Before the SANE environment is decommissioned, any outputs the researcher wishes to take out are reviewed by the data provider. No data leaves SANE without data provider approval. Once outputs are cleared, the environment is removed."@en ;
    schema:instrument <https://sane.surf.nl/> ;
    clariah:researchActivity tadirah:qualityAssurance ;
    schema:result ms:ExportedData .

# ── Sub-workflow C: Collection inspection and data fracture analysis ───────────
# Operational pattern — use before or during any workflow to assess data quality
# and make metadata limitations explicit. Grounds tool criticism in quantitative
# evidence from the Collection Inspector.
# Documented in: https://data.beeldengeluid.nl/showcases/data-fractures

ms:CollectionInspectionSubWorkflow
    a clariah:Workflow ;
    schema:name "Collection inspection and data fracture analysis"@en ;
    schema:description "Investigating metadata field completeness and enrichment coverage in a collection before or during a research workflow, in order to surface 'data fractures': gaps and inconsistencies caused by different annotation methods (archivist vs. AI vs. programme maker), temporal shifts in cataloguing practice, or uneven resource allocation (e.g. face recognition applied to news but not radio). Essential for tool criticism and for making informed methodological choices — e.g. whether to compare absolute hit counts or percentages, or whether ASR coverage is sufficient to support a speech-based corpus study."@en ;
    clariah:workflowStatus "Fully supported" ;
    dcterms:source <https://data.beeldengeluid.nl/showcases/data-fractures> ;
    schema:step ms:CI1, ms:CI2 .

ms:CI1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Inspect metadata completeness and enrichment coverage"@en ;
    schema:description "Use the Collection Inspector to examine field completeness over time and across collection segments. Key questions: What proportion of items have ASR transcripts? Are subject tags evenly distributed across time periods? Which metadata fields are sparse or absent for certain genres or date ranges?"@en ;
    schema:instrument ms:CollectionInspector ;
    clariah:researchActivity tadirah:browsing, tadirah:dataVisualization, tadirah:qualityAssurance ;
    schema:result ms:CollectionProfile .

ms:CI2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Document data fractures and methodological adjustments"@en ;
    schema:description "Record the gaps and inconsistencies found and document how they affect the research workflow — e.g. choosing percentages over absolute counts in the Compare Tool to compensate for temporal annotation gaps. Use the Reflexivity Tool to make this part of the methodology record."@en ;
    schema:instrument ms:ReflexivityTool, ms:CompareTool ;
    clariah:researchActivity tadirah:qualityAssurance, tadirah:defining ;
    clariah:optional true ;
    schema:result ms:MethodologyRecord .

# ── Workflow 12: Researcher-triggered enrichment on demand ────────────────────
# Aspirational — documents a widely expressed researcher need: triggering
# processing services (ASR, computer vision, NER) on a self-defined corpus
# when the required enrichment is absent or incomplete. Generalises to a
# researcher-facing processing service catalogue backed by compute infrastructure
# and a payment/access-allocation mechanism.
# Administrative steps use tadirah:managing as a pragmatic fallback; see README
# for discussion of the TaDiRaH gap for procedural/administrative workflow steps.

ms:OnDemandEnrichmentWorkflow
    a clariah:Workflow ;
    schema:name "Researcher-triggered enrichment on demand"@en ;
    schema:description "A researcher identifies a corpus in the Media Suite that lacks sufficient enrichment (e.g. no ASR transcripts for items they want to analyse for spoken content) and triggers a processing service from a researcher-facing catalogue — ASR, computer vision, named entity recognition — on their selected corpus. They are notified when processing is complete and can access the enriched data for further analysis. Generalises to a catalogue of processing services available on demand, backed by compute infrastructure (local, SURF, EU Cloud) and a payment or access-allocation mechanism (institutional affiliation, CLARIAH membership, NWO project budget)."@en ;
    clariah:workflowStatus "Aspirational" ;
    schema:releaseNotes "Requires: (1) a researcher-facing processing service catalogue; (2) on-demand compute infrastructure (SURF HPC, EU Cloud); (3) a payment or access-allocation mechanism for compute; (4) an asynchronous job notification mechanism; (5) re-ingestion of enriched data into the Media Suite collection layer."@en ;
    schema:step ms:ODE1, ms:ODE2, ms:ODE3, ms:ODE4 .

ms:ODE1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Inspect collection and define corpus"@en ;
    schema:description "Use the Collection Inspector to assess current enrichment coverage (e.g. what proportion of items in the target date range or genre have ASR transcripts). Build a personal corpus of items that lack the required enrichment and save to the Workspace."@en ;
    schema:instrument ms:CollectionInspector, ms:SearchTool, ms:Workspace ;
    clariah:researchActivity tadirah:browsing, tadirah:dataVisualization,
                             tadirah:qualityAssurance, clariah:Sampling ;
    schema:result ms:SelectedCorpus .

ms:ODE2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Select processing service from catalogue"@en ;
    schema:description "Choose a processing service (ASR, computer vision, NER, etc.) from a researcher-facing service catalogue. Configure parameters (language model, resolution, etc.) and specify the target corpus. This catalogue does not yet exist as a Media Suite or CLARIAH feature."@en ;
    clariah:researchActivity tadirah:managing .
    # NOTE: the concept of a researcher-facing processing service catalogue is
    # closely related to the EOSC notion of research services, and to ongoing
    # work in CLARIAH on making infrastructure services accessible to researchers
    # beyond platform-internal processing pipelines.

ms:ODE3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Submit job and verify access entitlement"@en ;
    schema:description "Submit the processing job. The system verifies the researcher's access entitlement and compute allocation — institutional affiliation, CLARIAH membership, or NWO project budget. Job is queued for execution on available compute infrastructure."@en ;
    clariah:researchActivity tadirah:managing .

ms:ODE4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Receive notification and access enriched corpus"@en ;
    schema:description "Researcher is notified (email or in-platform message) when processing is complete. Enriched data (transcripts, embeddings, annotations) is available in the Media Suite as a new data layer on the selected corpus, ready for further research workflows such as ms:ASRTranscriptResearchWorkflow or ms:OpenDataAnalysisWorkflow."@en ;
    clariah:researchActivity tadirah:dataIngestion ;
    schema:result ms:AnnotatedCorpus .

# ── Workflow 13: Oral history ASR, annotation, deposit, and ingestion ─────────
# Aspirational — documents the need of oral history researchers to have locally
# held interview recordings enriched by a Media Suite ASR service, corrected
# locally, deposited at DANS, and made accessible via the Media Suite.
# Two steps are aspirational: exposing the ASR service for researcher-supplied
# audio (currently NISV-internal only), and automated harvesting of new researcher
# deposits from DANS.

ms:OralHistoryIngestionWorkflow
    a clariah:Workflow ;
    schema:name "Oral history ASR, annotation, deposit, and Media Suite ingestion"@en ;
    schema:description "Oral historians bring locally held interview recordings to the Media Suite ASR service for transcription, correct the transcript locally, deposit the interview and transcript at DANS, and the collection becomes accessible and searchable via the Media Suite after automated harvesting. Addresses the specific need of oral history researchers to have their own data enriched by CLARIAH infrastructure, preserved in a certified repository, and made discoverable alongside institutionally held collections."@en ;
    clariah:workflowStatus "Aspirational" ;
    schema:releaseNotes "Two steps are currently aspirational: (1) the Media Suite ASR service (ms:ASRService) is applied to NISV archive collections internally and is not yet available as a web service for researcher-supplied audio; (2) the Media Suite does not yet automatically harvest new researcher deposits from DANS — the ms:DANSOralHistory collection is currently manually maintained."@en ;
    schema:step ms:OHI1, ms:OHI2, ms:OHI3, ms:OHI4, ms:OHI5 .

ms:OHI1 a schema:HowToStep ; schema:position 1 ;
    schema:name "Prepare local interview recordings"@en ;
    schema:description "Prepare locally held interview recordings (audio or video) in a format compatible with the ASR service. Collect and structure accompanying metadata: interviewer, interviewee, date, language, context. This step is fully supported with existing tools."@en ;
    clariah:researchActivity tadirah:managing .

ms:OHI2 a schema:HowToStep ; schema:position 2 ;
    schema:name "Submit recordings to Media Suite ASR service"@en ;
    schema:description "Upload recordings to the Media Suite ASR service for automatic transcription. Aspirational: ms:ASRService currently operates as an internal NISV pipeline; exposing it as a web service for researcher-supplied audio requires a separate API endpoint, authentication, and compute allocation mechanism. When implemented, language selection and model configuration should be researcher-controllable."@en ;
    schema:instrument ms:ASRService ;
    clariah:researchActivity tadirah:speechRecognizing ;
    schema:result ms:Transcript .

ms:OHI3 a schema:HowToStep ; schema:position 3 ;
    schema:name "Annotate and correct transcript locally"@en ;
    schema:description "Review and correct the ASR transcript using a local or web-based annotation tool (e.g. ELAN, Transcriber, or — if transcript editing is supported — the Media Suite Annotation Tool). Oral history researchers typically do detailed annotation: speaker identification, non-verbal cues, ASR error correction, thematic segments."@en ;
    clariah:researchActivity tadirah:audioAnnotation, tadirah:transcribing ;
    schema:result ms:AnnotatedCorpus .

ms:OHI4 a schema:HowToStep ; schema:position 4 ;
    schema:name "Deposit interview and transcript at DANS"@en ;
    schema:description "Deposit the interview recording and corrected transcript at DANS SSH Data Station with appropriate license and access conditions. The deposit URI (DOI) becomes the authoritative persistent identifier for this interview."@en ;
    schema:instrument <https://ssh.datastations.nl/> ;
    clariah:researchActivity tadirah:archiving ;
    schema:result ms:DepositedOutput .

ms:OHI5 a schema:HowToStep ; schema:position 5 ;
    schema:name "Media Suite harvests deposit and makes collection accessible"@en ;
    schema:description "The Media Suite automatically harvests metadata and transcripts from the DANS deposit, making the interview searchable and playable via the Media Suite interface alongside institutionally held oral history collections. Aspirational: Media Suite does not yet automatically harvest new researcher deposits from DANS; ms:DANSOralHistory is currently manually maintained. When implemented, this closes the loop between researcher-produced data and infrastructure-level discoverability."@en ;
    clariah:researchActivity tadirah:dataIngestion .
