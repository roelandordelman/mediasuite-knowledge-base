@prefix ms:      <https://mediasuite.clariah.nl/vocab#> .
@prefix clariah: <https://roelandordelman.github.io/mediasuite-knowledge-base/vocab#> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema:  <https://schema.org/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix euright: <http://publications.europa.eu/resource/authority/access-right/> .

# ── Licensing notes ───────────────────────────────────────────────────────────
# Two properties are used in combination following DCAT-AP 3.0:
#
#   dcterms:accessRights  — machine-readable access class (EU Publications Office
#                           access-right vocabulary: PUBLIC / RESTRICTED / NON_PUBLIC).
#                           DCAT-AP mandates a URI value here; literals are a common
#                           but non-standard shortcut.
#
#   schema:conditionsOfAccess — human-readable prose describing the specific access
#                           conditions (which institutions, login routes, etc.).
#
#   dcterms:license       — the reuse license as a URI (CC0, Public Domain Mark, etc.).
#                           Added only where the license is confirmed and collection-wide.
#                           Item-level licenses (common in mixed collections) are available
#                           from the publisher's LOD endpoint and are not duplicated here.
#                           Restricted collections carry no dcterms:license because
#                           IPR-protected content has no open reuse license to declare.
#
# CC URIs used:
#   CC0 1.0 Universal:   https://creativecommons.org/publicdomain/zero/1.0/
#   Public Domain Mark:  https://creativecommons.org/publicdomain/mark/1.0/

# ── Intended architecture (partially implemented) ─────────────────────────────
#
#   data.beeldengeluid.nl / KB / EYE / ...  ← publisher platforms; authoritative source
#         ↓ publishes to / harvested by
#   NDE dataset register                    ← Dutch national registry for cultural heritage
#   (+ SSHOC marketplace, CLARIN VLO)       ← EU-level registries harvesting from NDE
#         ↓ should be harvested by
#   mediasuitedata.clariah.nl               ← Media Suite CKAN registry: which collections
#                                              are accessible via the Media Suite specifically
#         ↓ queried by VREs; access via DAB + ODRL (SSHOC-NL, in development)
#   ms:MediaSuite / sane.surf.nl            ← VREs that expose collections to researchers
#
# Note on data.beeldengeluid.nl: this is NISV's own Linked Open Data publication
# platform — the *publisher* of NISV datasets. NDE harvests FROM it. Dataset URIs
# such as http://data.beeldengeluid.nl/id/dataset/0002 are the authoritative identifiers
# for NISV collections and are used in owl:sameAs links below.
#
# Current reality: mediasuitedata.clariah.nl is partly manually maintained and
# not fully linked to resource maintainers. owl:sameAs links below point to NDE/
# publisher URIs where confirmed; [NO_NDE_URI] flags collections not yet registered.
# Full dataset descriptions belong in the registries — this file only models the
# Media Suite's access relationship to each collection.
#
# Data currency: these descriptions were last reviewed 2026-04-30. Each entity
# carries dcterms:modified (last reviewed) and dcterms:source (where to check for
# updates). Collection metadata changes slowly but can accelerate during active
# registry cleanup. Long-term solution: SPARQL federation against NDE/publisher
# endpoints + NDE change notifications when available.

# ── Catalog stubs ─────────────────────────────────────────────────────────────

<https://datasetregister.netwerkdigitaalerfgoed.nl/>
    a dcat:Catalog ;
    rdfs:label "NDE Dataset Register"@en ;
    schema:description "The Dutch national dataset register for cultural heritage institutions, maintained by Netwerk Digitaal Erfgoed (NDE). Authoritative source for dataset descriptions from Dutch heritage organisations."@en .

<https://mediasuitedata.clariah.nl/>
    a dcat:Catalog ;
    rdfs:label "Media Suite Collection Registry"@en ;
    schema:description "CKAN-based registry of collections accessible via the CLARIAH Media Suite. Intended to harvest from national registries; currently partly manually maintained."@en ;
    dcat:isPartOf <https://datasetregister.netwerkdigitaalerfgoed.nl/> .

# ── NISV collections ──────────────────────────────────────────────────────────
# Sound & Vision (NISV) publishes collection descriptions at data.beeldengeluid.nl
# and as Linked Open Data via cat.apis.beeldengeluid.nl/sparql.
# The full archive (ms:NISVArchive) is the parent; sub-collections and open
# subsets are modelled as dcterms:hasPart children.

ms:NISVArchive
    a dcat:Dataset ;
    rdfs:label "Sound & Vision Archive"@en ;
    skos:altLabel "Beeld & Geluid archief"@nl ;
    schema:description "The main audiovisual archive of the Netherlands Institute for Sound & Vision (NISV), covering Dutch television, radio, and related media from the 1890s to the present."@en ;
    dcterms:publisher <https://www.beeldengeluid.nl/> ;
    dcterms:accessRights euright:RESTRICTED ;
    schema:conditionsOfAccess "Restricted — access to IPR-protected content requires affiliation with a rights-holding institution via SURFconext."@en ;
    schema:url <https://data.beeldengeluid.nl/datasets/nisv-media-catalog> ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <https://data.beeldengeluid.nl/datasets/nisv-media-catalog> ;
    clariah:partOf ms:MediaSuite ;
    # [NO_NDE_URI] — NISV full archive not yet registered as a single entry in NDE.
    dcterms:hasPart ms:SoundVisionTelevisionArchive, ms:SoundVisionRadioArchive,
                    ms:OpenBeelden, ms:RadioOranje, ms:NISVArtCollection,
                    ms:AmateurFilmCollection, ms:DutchProgramGuides, ms:KijkLuistercijfers .

ms:SoundVisionTelevisionArchive
    a dcat:Dataset ;
    rdfs:label "Sound & Vision Television Archive"@en ;
    dcterms:publisher <https://www.beeldengeluid.nl/> ;
    dcterms:accessRights euright:RESTRICTED ;
    dcterms:isPartOf ms:NISVArchive ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <https://data.beeldengeluid.nl/datasets> ;
    clariah:partOf ms:MediaSuite .
    # [NO_NDE_URI]

ms:SoundVisionRadioArchive
    a dcat:Dataset ;
    rdfs:label "Sound & Vision Radio Archive"@en ;
    dcterms:publisher <https://www.beeldengeluid.nl/> ;
    dcterms:accessRights euright:RESTRICTED ;
    dcterms:isPartOf ms:NISVArchive ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <https://data.beeldengeluid.nl/datasets> ;
    clariah:partOf ms:MediaSuite .
    # [NO_NDE_URI]

ms:OpenBeelden
    a dcat:Dataset ;
    rdfs:label "Open Beelden"@en ;
    schema:description "Openly licensed historical audiovisual material from Sound & Vision, including Polygoon newsreels and early 20th-century films. 7,092 items."@en ;
    dcterms:publisher <https://www.beeldengeluid.nl/> ;
    dcterms:accessRights euright:PUBLIC ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    # License confirmed from http://data.beeldengeluid.nl/id/dataset/0002 (authoritative LOD source)
    dcterms:isPartOf ms:NISVArchive ;
    dcterms:hasPart ms:Natuurbeelden ;
    schema:url <https://data.beeldengeluid.nl/datasets/open-beelden> ;
    dcat:accessService ms:OpenImagesAPI ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <http://data.beeldengeluid.nl/id/dataset/0002> ;
    clariah:partOf ms:MediaSuite ;
    owl:sameAs <http://data.beeldengeluid.nl/id/dataset/0002> .
    # NDE URI confirmed: http://data.beeldengeluid.nl/id/dataset/0002

ms:Natuurbeelden
    a dcat:Dataset ;
    rdfs:label "Open Beelden Natuurbeelden"@en ;
    schema:description "Open collection of nature video fragments (4,000+ items) from Sound & Vision, accessible via the Open Beelden API."@en ;
    dcterms:publisher <https://www.beeldengeluid.nl/> ;
    dcterms:accessRights euright:PUBLIC ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    # License inferred from parent dataset ms:OpenBeelden (CC0 per data.beeldengeluid.nl); verify against individual item metadata if needed
    dcterms:isPartOf ms:OpenBeelden ;
    dcat:accessService ms:OpenImagesAPI ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <https://data.beeldengeluid.nl/datasets> ;
    clariah:partOf ms:MediaSuite .
    # [NO_NDE_URI] — not separately registered; part of Open Beelden dataset.

ms:RadioOranje
    a dcat:Dataset ;
    rdfs:label "Radio Oranje"@en ;
    schema:description "NISV collection of Dutch-language wartime radio broadcasts (1940–1945). Public Domain under Dutch law."@en ;
    dcterms:publisher <https://www.beeldengeluid.nl/> ;
    dcterms:accessRights euright:PUBLIC ;
    dcterms:license <https://creativecommons.org/publicdomain/mark/1.0/> ;
    # Confirmed Public Domain: "According to Dutch law these recordings are in the Public Domain"
    # (data.beeldengeluid.nl/datasets/radio-oranje)
    dcterms:isPartOf ms:NISVArchive ;
    schema:url <https://data.beeldengeluid.nl/datasets/radio-oranje> ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <https://data.beeldengeluid.nl/datasets/radio-oranje> ;
    clariah:partOf ms:MediaSuite .
    # [NO_NDE_URI] — not separately registered in NDE.

