# ── Partner collections ────────────────────────────────────────────────────────

ms:DANSOralHistory
    a dcat:Dataset ;
    rdfs:label "DANS Oral History Archive"@en ;
    schema:description "Oral history interview collections archived at DANS, including the Getuigenverhalen (Witness Testimonies) collection of ~500 interviews (2006–2010)."@en ;
    dcterms:publisher <https://dans.knaw.nl/> ;
    dcterms:accessRights euright:PUBLIC ;
    schema:conditionsOfAccess "Open — DANS Open Data; specific license varies by dataset deposit."@en ;
    # [NO_LICENSE_URI] — DANS open datasets use various licenses; verify per deposit at easy.dans.knaw.nl
    schema:url <https://easy.dans.knaw.nl/ui/datasets/id/easy-dataset:50198> ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <https://easy.dans.knaw.nl/ui/datasets/id/easy-dataset:50198> ;
    clariah:partOf ms:MediaSuite .
    # [NO_NDE_URI] — archived in DANS; not separately in NDE dataset register.

ms:KBNewspapers
    a dcat:Dataset ;
    rdfs:label "KB Newspaper Collection"@en ;
    skos:altLabel "Delpher Newspapers"@en ;
    schema:description "Digitised Dutch newspapers (1618–1995) from the Koninklijke Bibliotheek (KB). Open Domain for pre-1879 material; restricted for later dates."@en ;
    dcterms:publisher <https://www.kb.nl/> ;
    dcterms:accessRights euright:NON_PUBLIC ;
    schema:conditionsOfAccess "Mixed — pre-1879 material is Public Domain; post-1879 access is restricted."@en ;
    # [NO_LICENSE_URI] — license differs by date range; item-level license info available from data.bibliotheken.nl
    schema:url <https://www.kb.nl/en/research-find/datasets/delpher-newspapers> ;
    dcterms:modified "2026-04-30" ;
    dcterms:source <https://www.kb.nl/en/research-find/datasets/delpher-newspapers> ;
    clariah:partOf ms:MediaSuite .
    # [NO_NDE_URI] — available via KB Linked Data (data.bibliotheken.nl) but not
    # found as a distinct entry in the NDE dataset register.

